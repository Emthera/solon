{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Emthera/spec/main/track-spec-v1.7.json",
  "title": "Clinical Track Logic",
  "description": "Patient-specific manifest that aggregates authored protocols and manages the active monitoring state.",
  "type": "object",
  "required": ["track"],
  "properties": {
    "track": {
      "type": "object",
      "required": ["meta", "lineage", "factors", "symptoms", "protocols"],
      "properties": {
        "meta": {
          "type": "object",
          "required": ["track_id", "icd", "code"],
          "properties": {
            "track_id": { "type": "string", "format": "uuid" },
            "version": { "type": "string", "description": "The current version of the entire track manifest." },
            "icd": { "type": "string", "format": "uri" },
            "code": { "type": "string", "description": "Specific ICD code (e.g., 7A00)." },
            "display_name": { "type": "string" },
            "status": { "type": "string", "enum": ["active", "closed", "branched"] }
          }
        },
        "lineage": {
          "type": "object",
          "properties": {
            "parents": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["ref", "version"],
                "properties": {
                  "ref": { "type": "string", "format": "uri" },
                  "version": { "type": "string" }
                }
              }
            }
          }
        },
        "factors": {
          "type": "array",
          "description": "Registry of environmental or geospatial variables defined in the system.",
          "items": {
            "type": "object",
            "required": ["id", "label", "spec_ref"],
            "properties": {
              "id": { "type": "string", "description": "Unique slug (e.g., env_humidity)." },
              "label": { "type": "string" },
              "created_at": { "type": "string", "format": "date-time" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "spec_ref": { "type": "string", "format": "uri", "description": "Link to the external specification (LOINC/SNOMED)." }
            }
          }
        },
        "symptoms": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "providers"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "influencing_factors": { 
                "type": "array", 
                "items": { "type": "string" }, 
                "description": "IDs from the factors array that exacerbate this symptom." 
              },
              "measurement": {
                "type": "object",
                "properties": {
                  "scale": { "type": "string", "default": "1-10" },
                  "qualifiers": { "type": "array", "items": { "type": "string" } }
                }
              },
              "providers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["provider_type"],
                  "properties": {
                    "provider_type": { "type": "string", "enum": ["auto", "manual"] },
                    "manual_input_config": {
                      "type": "object",
                      "properties": {
                        "ui_control": { "type": "string", "enum": ["slider", "binary", "dropdown"] },
                        "options": { "type": "array", "items": { "type": "string" } }
                      }
                    },
                    "provider_ref": { "type": "string", "format": "uri" }
                  }
                }
              }
            }
          }
        },
        "protocols": {
          "type": "array",
          "description": "List of active protocol references authored by physicians.",
          "items": {
            "type": "object",
            "required": ["protocol_ref", "author_ref", "assigned_at"],
            "properties": {
              "protocol_ref": { "type": "string", "format": "uri-reference", "description": "Relative path to the authored YAML/JSON protocol file." },
              "author_ref": { "type": "string", "format": "uri-reference", "description": "Link to the physician profile." },
              "assigned_at": { "type": "string", "format": "date-time" },
              "status": { "type": "string", "enum": ["ordered", "active", "paused", "completed", "canceled"] }
            }
          }
        }
      }
    }
  }
}
