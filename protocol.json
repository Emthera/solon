{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Solon Clinical Protocol",
  "description": "A standalone medical blueprint defining tests, medications, diets, and context for a specific condition.",
  "type": "object",
  "required": ["meta"],
  "properties": {
    "meta": {
      "type": "object",
      "description": "Administrative metadata identifying the protocol's origin and version.",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The effective date or last revision date of this protocol." },
        "display_name": { "type": "string", "description": "The title of the protocol shown to clinicians (e.g., 'Gastroenterology Protocol')." },
        "author": { "type": "string", "description": "Reference path or URI to the physician's profile who authored this specific logic." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Keywords for indexing and filtering (e.g., 'gastroenterology', 'chronic')." }
      }
    },
    "tests": {
      "type": "array",
      "description": "Diagnostic orders (Labs, Imaging) required by this protocol.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "LOINC code or internal test ID." },
          "label": { "type": "string" },
          "provider": { "type": "string", "description": "The coding system used (e.g., 'LOINC', 'INTERNAL')." },
          "category": { "type": "string", "description": "e.g., 'Imaging', 'Laboratory'." },
          "frequency": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["event", "on_demand", "periodic"] },
              "urgency": { "type": "string", "default": "routine" }
            }
          },
          "expected_type": { "type": "string", "description": "The data format of the result (e.g., 'report', 'decimal')." }
        }
      }
    },
    "medications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "provider", "label", "substance", "route", "frequency"],
        "properties": {
          "id": { "type": "string", "description": "Primary code (e.g., ATC code M01AE17)." },
          "provider": { "type": "string", "description": "System identifying the ID (e.g., ATC, RxNorm)." },
          "label": { "type": "string", "description": "Full clinical name including concentration/form." },
          "substance": {
            "type": "object",
            "required": ["name", "dosage"],
            "properties": {
              "name": { "type": "string", "description": "International Nonproprietary Name (INN)." },
              "dosage": { "type": "string", "description": "e.g., 50mg, 10ml." },
              "form": { "type": "string", "description": "e.g., solution, tablet, aerosol." }
            }
          },
          "route": {
            "type": "object",
            "required": ["type", "provider"],
            "properties": {
              "type": { "type": "string", "description": "Standardized route (e.g., intravenous)." },
              "provider": { "type": "string", "description": "Authority for the term (e.g., EDQM, FDA)." }
            }
          },
          "frequency": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["cron", "on_demand", "event"] },
              "instructions": { "type": "string", "description": "Human-readable administration logic." },
              "cron": { "type": "string" }
            }
          }
        }
      }
    },
    "diet": {
      "type": "array",
      "description": "Nutritional and hydration requirements.",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "regime": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "SNOMED code for the diet type." },
              "label": { "type": "string" }
            }
          },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "id": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
